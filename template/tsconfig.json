{
  "compilerOptions": {
    // Modules
    "module": "commonjs",
    "target": "esnext",

    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Type Declarations
    "types": ["node"],

    // Source Maps & Declarations
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,

    // JSX
    "jsx": "react-jsx",

    // Interop Constraints
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
